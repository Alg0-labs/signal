ANTHROPIC_API_KEY=sk-ant-...
MORALIS_API_KEY=...
FRONTEND_URL=http://localhost:3000
PORT=3001

# CoinMarketCap Portfolio MCP server (Streamable HTTP).
# Defaults to the deployed server; override to point at a local instance.
MCP_SERVER_URL=https://crypto-portfolio-mcp.onrender.com/mcp/

# RAG for "Talk to the chart" (optional — feature degrades gracefully if unset)
VOYAGE_API_KEY=pa-...                 # https://dashboard.voyageai.com (embeddings)
PINECONE_API_KEY=pcsk-...             # https://app.pinecone.io (vector DB)
PINECONE_INDEX=signal-news            # created automatically on first ingest
PINECONE_CLOUD=aws                    # aws | gcp | azure
PINECONE_REGION=us-east-1

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

