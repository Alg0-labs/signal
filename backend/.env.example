ANTHROPIC_API_KEY=sk-ant-...
MORALIS_API_KEY=...
FRONTEND_URL=http://localhost:3000
PORT=3001

# RAG for "Talk to the chart" (optional — feature degrades gracefully if unset)
VOYAGE_API_KEY=pa-...                 # https://dashboard.voyageai.com (embeddings)
PINECONE_API_KEY=pcsk-...             # https://app.pinecone.io (vector DB)
PINECONE_INDEX=signal-news            # created automatically on first ingest
PINECONE_CLOUD=aws                    # aws | gcp | azure
PINECONE_REGION=us-east-1

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Wallet snapshot TTL (ms) — on GET wallet / chat / market, refresh from indexer if older than this
WALLET_SNAPSHOT_TTL_MS=3600000

# Min interval between manual UI refreshes per address (ms)
WALLET_REFRESH_COOLDOWN_MS=30000

